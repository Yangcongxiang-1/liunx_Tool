# 飞书应用凭证（必填）
# 在 https://open.feishu.cn/app 创建应用后获取
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# AI 自动回复开关（设为 false 可关闭）
AI_RESPONSE_ENABLED=true

# 机器人自己的 open_id（用于过滤自己的消息，防止循环）
# 启动日志可见：open_id=ou_xxx...
BOT_OPEN_ID=

# 运行时参数（可按需调整）
# POLL_INTERVAL=1.5     # inbox 轮询间隔（秒）
# STABLE_WAIT=5         # AI 回复稳定检测等待时间（秒）
# MSG_FRESH_SEC=30      # 消息时效过滤阈值（秒）
# OPENCODE_PORT=4096    # OpenCode Web 服务端口
